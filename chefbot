        "id": "VsZYXn8n6UPh",
        "outputId": "63c30b7e-4733-4d0f-e71e-5303490d2916"
      },
      "execution_count": 3,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Classi selezionate:\n",
            "['pizza', 'hamburger', 'sushi', 'ramen', 'spaghetti_bolognese', 'caesar_salad', 'cheesecake', 'baklava', 'tacos', 'ice_cream']\n",
            "Mappa classi:\n",
            "{'pizza': 0, 'hamburger': 1, 'sushi': 2, 'ramen': 3, 'spaghetti_bolognese': 4, 'caesar_salad': 5, 'cheesecake': 6, 'baklava': 7, 'tacos': 8, 'ice_cream': 9}\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "food101_path = tf.keras.utils.get_file(\n",
        "    fname=\"food-101.tar.gz\",\n",
        "    origin=\"http://data.vision.ee.ethz.ch/cvl/food-101.tar.gz\",\n",
        "    extract=True,\n",
        "    cache_dir=\".\",\n",
        "    cache_subdir=\"datasets\"\n",
        ")\n",
        "\n",
        "# Corrected DATASET_DIR to use the full extracted path including the 'food-101' subdirectory\n",
        "DATASET_DIR = pathlib.Path(food101_path) / \"food-101\"\n",
        "IMAGES_DIR = DATASET_DIR / \"images\"\n",
        "META_DIR = DATASET_DIR / \"meta\"\n",
        "\n",
        "print(\"Dataset scaricato in:\", DATASET_DIR)\n",
        "print(\"Cartella immagini:\", IMAGES_DIR)\n",
        "print(\"Cartella meta:\", META_DIR)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "YUU6KFRx6cRA",
        "outputId": "9265e231-8f6a-4daf-bbac-08dcf9097b28"
      },
      "execution_count": 8,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Dataset scaricato in: datasets/food-101_extracted/food-101\n",
            "Cartella immagini: datasets/food-101_extracted/food-101/images\n",
            "Cartella meta: datasets/food-101_extracted/food-101/meta\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "def load_food101_split(split_file, selected_classes):\n",
        "    image_paths = []\n",
        "    labels = []\n",
        "\n",
        "    with open(split_file, \"r\") as f:\n",
        "        lines = f.read().splitlines()\n",
        "\n",
        "    for line in lines:\n",
        "        class_name = line.split(\"/\")[0]\n",
        "\n",
        "        if class_name in selected_classes:\n",
        "            image_path = str(IMAGES_DIR / f\"{line}.jpg\")\n",
        "            label = class_to_index[class_name]\n",
        "\n",
        "            image_paths.append(image_path)\n",
        "            labels.append(label)\n",
        "\n",
        "    return image_paths, labels\n",
        "\n",
        "\n",
        "train_paths, train_labels = load_food101_split(\n",
        "    META_DIR / \"train.txt\",\n",
        "    SELECTED_CLASSES\n",
        ")\n",
        "\n",
        "val_paths, val_labels = load_food101_split(\n",
        "    META_DIR / \"test.txt\",\n",
        "    SELECTED_CLASSES\n",
        ")\n",
        "\n",
        "print(\"Immagini train:\", len(train_paths))\n",
        "print(\"Immagini validation:\", len(val_paths))\n",
        "print(\"Numero classi:\", len(SELECTED_CLASSES))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "T6ltx9346iwS",
        "outputId": "a29f8abc-42c6-4a56-dd36-5d752c9d9486"
      },
      "execution_count": 9,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Immagini train: 7500\n",
            "Immagini validation: 2500\n",
            "Numero classi: 10\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "def preprocess_image(image_path, label):\n",
        "    image = tf.io.read_file(image_path)\n",
        "    image = tf.image.decode_jpeg(image, channels=3)\n",
        "    image = tf.image.resize(image, (IMG_SIZE, IMG_SIZE))\n",
        "    image = tf.keras.applications.mobilenet_v2.preprocess_input(image)\n",
        "    return image, label\n",
        "\n",
        "\n",
        "train_data = tf.data.Dataset.from_tensor_slices((train_paths, train_labels))\n",
        "train_data = (\n",
        "    train_data\n",
        "    .shuffle(buffer_size=len(train_paths), seed=SEED)\n",
        "    .map(preprocess_image, num_parallel_calls=AUTOTUNE)\n",
        "    .batch(BATCH_SIZE)\n",
        "    .prefetch(AUTOTUNE)\n",
        ")\n",
        "\n",
        "val_data = tf.data.Dataset.from_tensor_slices((val_paths, val_labels))\n",
        "val_data = (\n",
        "    val_data\n",
        "    .map(preprocess_image, num_parallel_calls=AUTOTUNE)\n",
        "    .batch(BATCH_SIZE)\n",
        "    .prefetch(AUTOTUNE)\n",
        ")\n",
        "\n",
        "print(\"Dataset TensorFlow creati correttamente\")"
      ],
      "metadata": {
        "colab": {
