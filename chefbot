        "def mood_search(user_query, top_k=3):\n",
        "    query_embedding = semantic_model.encode([user_query])\n",
        "    similarities = cosine_similarity(query_embedding, food_embeddings)[0]\n",
        "\n",
        "    best_indices = similarities.argsort()[::-1][:top_k]\n",
        "\n",
        "    results = []\n",
        "\n",
        "    for idx in best_indices:\n",
        "        label = food_labels[idx]\n",
        "        data = food_db[label]\n",
        "\n",
        "        results.append({\n",
        "            \"label\": label,\n",
        "            \"score\": float(similarities[idx]),\n",
        "            \"info\": data\n",
        "        })\n",
        "\n",
        "    return results\n",
        "\n",
        "\n",
        "results = mood_search(\"voglio qualcosa di fresco e leggero\")\n",
        "\n",
        "for result in results:\n",
        "    print(result[\"info\"][\"name\"], \"-\", round(result[\"score\"], 3))"
