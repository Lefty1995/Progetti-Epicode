    {
      "cell_type": "code",
      "source": [
        "SELECTED_CLASSES = [\n",
        "    \"pizza\",\n",
        "    \"hamburger\",\n",
        "    \"sushi\",\n",
        "    \"ramen\",\n",
        "    \"spaghetti_bolognese\",\n",
        "    \"caesar_salad\",\n",
        "    \"cheesecake\",\n",
        "    \"baklava\",\n",
        "    \"tacos\",\n",
        "    \"ice_cream\"\n",
        "]\n",
        "\n",
        "class_to_index = {name: idx for idx, name in enumerate(SELECTED_CLASSES)}\n",
        "index_to_class = {idx: name for name, idx in class_to_index.items()}\n",
        "\n",
        "print(\"Classi selezionate:\")\n",
        "print(SELECTED_CLASSES)\n",
        "\n",
        "print(\"Mappa classi:\")\n",
        "print(class_to_index)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
